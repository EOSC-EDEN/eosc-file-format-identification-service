# Siegfried — binary path (subprocess mode) or REST server URL (sidecar mode)
FFIS_SIEGFRIED_BINARY=sf
# FFIS_SIEGFRIED_SERVER_URL=http://siegfried:5138

# Magika (AI-assisted fallback for unidentified files)
FFIS_MAGIKA_ENABLED=true

# Apache Tika (optional — requires Java and Tika server)
FFIS_TIKA_ENABLED=false
# FFIS_TIKA_SERVER_URL=http://tika:9998

# SQLite result cache
FFIS_CACHE_ENABLED=true
FFIS_CACHE_DB_PATH=/tmp/ffis_cache.db

# API
FFIS_API_HOST=0.0.0.0
FFIS_API_PORT=8000

# Registry resolution hierarchy (comma-separated, highest priority first)
# FFIS_REGISTRY_HIERARCHY=PRONOM,LOC,WIKIDATA,MIME
